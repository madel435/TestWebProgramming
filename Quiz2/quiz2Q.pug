doctype html
html
  head
    title Finance IQ — Quiz
    style.
      body {
        background:#ffffff;
        color:#000;
        font-family: Arial, sans-serif;
        display:flex;
        justify-content:center;
        padding:40px 20px;
      }

      #app {
        width:100%;
        max-width:600px;
      }

      .page-title {
        text-align:center;
        font-size:1.8rem;
        font-weight:bold;
        margin-bottom:5px;
      }

      .page-sub {
        text-align:center;
        font-size:.8rem;
        color:#555;
        margin-bottom:30px;
      }

      .question-block {
        border:1px solid #ccc;
        padding:20px;
        border-radius:8px;
        margin-bottom:15px;
        display:flex;
        flex-direction:column;
        align-items:center;
        text-align:center;
      }

      .q-num {
        font-size:.75rem;
        color:#555;
        margin-bottom:8px;
      }

      .question-text {
        font-size:1rem;
        font-weight:600;
        margin-bottom:15px;
      }

      .stars {
        display:flex;
        justify-content:center;
        gap:10px;
      }

      .star-btn {
        background:none;
        border:none;
        cursor:pointer;
        display:flex;
        flex-direction:column;
        align-items:center;
      }

      .star {
        font-size:1.6rem;
        color:#bbb;
      }

      .num {
        font-size:.7rem;
        color:#777;
      }

      .star-btn:hover .star {
        color:#000;
      }

      .star-btn.active .star,
      .star-btn.active .num {
        color:#000;
      }

      .submit-wrap {
        text-align:center;
        margin-top:25px;
      }

      .btn {
        background:#000;
        color:#fff;
        padding:12px 40px;
        border:none;
        border-radius:30px;
        cursor:pointer;
        font-size:1rem;
      }

      .btn:disabled {
        opacity:.4;
        cursor:not-allowed;
      }

      .counter {
        margin-top:10px;
        font-size:.8rem;
        color:#555;
      }

  body
    #app
      p.page-title Finance IQ
      p.page-sub Rate each statement from 1 to 5, 

      - var questions = ["I keep track of how much money I spend each week.", "Before I buy something, I check whether I have enough money.", "I set aside money regularly so I can buy something I want later.", "I find it easy to resist spending now in order to save for the future.", "I feel confident that I understand what a bank account is and how it works.", "I understand the difference between a debit card and a credit card.", "I know what interest means when borrowing or saving money.", "I understand that people earn money in different ways.", "When I buy something, I compare prices before deciding.", "Advertisements influence what I decide to buy.", "I think carefully about whether I need something before I buy it.", "I feel confident making a payment using a phone or electronic device.", "I know how to keep my personal information safe when paying online.", "I believe it is important for young people to understand how money works.", "I feel in control of my financial decisions."]

      each q, i in questions
        .question-block(data-q=i)
          span.q-num Question #{i + 1}
          p.question-text #{q}
          .stars
            each val in [1,2,3,4,5]
              button.star-btn(type='button' data-q=i data-val=val)
                span.star ★
                span.num #{val}

      .submit-wrap
        button#submit-btn.btn(disabled) Submit Quiz
        p.counter #[span#answered 0] of 15 answered

    script.
      const total = 15;
      const ratings = {};
      const submitBtn = document.getElementById('submit-btn');
      const answeredEl = document.getElementById('answered');

      document.querySelectorAll('.star-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const q = parseInt(btn.dataset.q);
          const val = parseInt(btn.dataset.val);
          ratings[q] = val;

          const block = document.querySelector('.question-block[data-q="' + q + '"]');
          block.querySelectorAll('.star-btn').forEach(b => {
            b.classList.toggle('active', parseInt(b.dataset.val) === val);
          });

          answeredEl.textContent = Object.keys(ratings).length;
          submitBtn.disabled = Object.keys(ratings).length < total;
        });
      });

      submitBtn.addEventListener('click', () => {
        alert('Quiz complete! Ratings: ' + JSON.stringify(ratings));
      });
