//This is the login page for the premium quiz 
//need to add a page to validate the information 

doctype html
html
  head
    title Login
    style.
      body {
        background: #ffffff;
        color: var(--text);
        font-family: 'Space Mono', monospace;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container { 
        max-width: 880px; 
        width: 100%; 
      }

      /* HEADER */
      .header { 
        text-align: center; 
        margin-bottom: 3.5rem; 
      }

      .logo {
        
        color: #000000;
        font-size: 2.0rem;
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto;
      }

      .tagline {
        color: #000000;
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 1.2rem;
      }

      .description {
        color: #ffffff;
        font-size: 0.92rem;
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto;
      }

      form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 360px;
        margin: 0 auto;
      }

      input {
        padding: 0.6rem 0.8rem;
        border-radius: 6px;
        border: 1px solid #000000;
        background: #ffffff;

      }

      button {
        padding: 0.7rem 1rem;
        border: none;
        border-radius: 6px;
        background: var(--accent);
        color: #000000;
        font-weight: bold;
        cursor: pointer;
      }

  body
    .container
      .header
        h1.logo Sign In
        p.tagline Please sign in to access the Premium Quiz

      form(action="/Quiz2/login" method="POST")
        label(for="username") Username
        input(type="text" name="username" required)

        label(for="password") Password
        input(type="password" name="password" required)

        button(type="submit") Sign In
