doctype html
html
  head
    title Finance IQ — Know Your Money
    style.
      :root {
        --accent: #7C8DA6;
        --bg: #BEB3C3;
        --card:#DDD3C9;
        --border: #2a2a3a;
        --text: #928E5E;
        --muted: #666;
        --radius: 14px;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: 'Space Mono', monospace;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
      }

      .container { max-width: 880px; width: 100%; }

      /* HEADER */
      .header { text-align: center; margin-bottom: 3.5rem; }

      .logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: clamp(2.8rem, 8vw, 4.5rem);
        background: linear-gradient(135deg, var(--accent), #00c8ff);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
        margin-bottom: 0.6rem;
      }

      .tagline {
        color: var(--muted);
        font-size: 0.8rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        margin-bottom: 1.2rem;
      }

      .description {
        color: #999;
        font-size: 0.92rem;
        line-height: 1.7;
        max-width: 560px;
        margin: 0 auto;
      }

      /* CARDS */
      .quiz-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
      }

      @media (max-width: 640px) {
        .quiz-cards { grid-template-columns: 1fr; }
      }

      .quiz-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
      }

      .quiz-card:hover {
        transform: translateY(-4px);
        border-color: var(--accent);
        box-shadow: 0 12px 40px rgba(0,255,136,0.1);
      }

      .quiz-card h2 {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        color: var(--accent);
      }

      .quiz-card p {
        color: #999;
        font-size: 0.85rem;
        line-height: 1.7;
        flex: 1;
      }

      .btn {
        display: block;
        background: var(--accent);
        color: #000;
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 0.95rem;
        padding: 14px 24px;
        border-radius: 50px;
        border: none;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        letter-spacing: 0.04em;
        margin-top: 0.5rem;
        transition: transform 0.15s, box-shadow 0.15s;
      }

      .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(0,255,136,0.25);
      }

      .footer {
        text-align: center;
        color: var(--muted);
        font-size: 0.78rem;
        margin-top: 3rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
      }

  body
    .container
      .header
        .logo Finance IQ
        p.tagline Know your money. Own your future.
        p.description Two ways to assess your financial literacy. Pick the quiz that fits you — knowledge test or self-reflection.

      .quiz-cards
        .quiz-card
          h2 Financial Knowledge Quiz
          p Multiple-choice questions covering budgeting, investing, credit, and taxes. Get instant feedback and learn why each answer matters.
          a.btn(href="Quiz1/quiz1") Take the Knowledge Quiz →

        .quiz-card
          h2 Financial Self Assessment
          p Rate yourself on a 1–5 scale across 20 financial habits. Get personalized guidance on areas to improve.
          a.btn(href="Quiz2/login") Take the Self Assessment →

        .quiz-card
          h2 General Resource
          p A list of general resources and topics to research. We are not financial advisors do research at your own risk
          a.btn(href="resourcepage") Resource Page →

        .quiz-card
          h2 Financial Advisor
          p Get connected with a Financial Advisor and make the recommendations a reality. Take your quizzes to the Financial Advisor so that they can assist with checking your goals off.
          a.btn(href="FAdvisor") Get connected with a Financial Advisor →